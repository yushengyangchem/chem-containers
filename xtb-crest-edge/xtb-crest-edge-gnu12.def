Bootstrap: docker-archive
From: ./ubuntu22.04.tar

%labels
    Maintainer yangys
    App xTB and CREST in ubuntu 22.04

%files
    ./xtb-bleed-20260210.tar.xz /opt
    ./crest-gnu-12-ubuntu-latest-20260210.tar.xz /opt

%post
    echo 'deb http://mirrors.ustc.edu.cn/ubuntu/ jammy main restricted universe multiverse
deb http://mirrors.ustc.edu.cn/ubuntu/ jammy-updates main restricted universe multiverse
deb http://mirrors.ustc.edu.cn/ubuntu/ jammy-backports main restricted universe multiverse
deb http://mirrors.ustc.edu.cn/ubuntu/ jammy-security main restricted universe multiverse
' | tee /etc/apt/sources.list

    apt-get update && apt-get install -y --no-install-recommends xz-utils

    tar -xf /opt/xtb-bleed-20260210.tar.xz -C /opt
    tar -xf /opt/crest-gnu-12-ubuntu-latest-20260210.tar.xz -C /opt
    rm -rf /opt/xtb-bleed-20260210.tar.xz
    rm -rf /opt/crest-gnu-12-ubuntu-latest-20260210.tar.xz

    echo "/opt/xtb-bleed/lib" > /etc/ld.so.conf.d/xtb-bleed.conf
    ldconfig

    apt-get purge -y xz-utils

    apt-get autoremove -y
    apt-get clean
    rm -rf /var/lib/apt/lists/* /root/.cache

%environment
    export PATH=$PATH:/opt/crest
    export PATH=$PATH:/opt/xtb-bleed/bin

%runscript
    exec "$@"
